{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run Unit Tests Debug",
            "type": "shell",
            "command": "python3",
            "args": [
                "${workspaceFolder}/../unitTests.py",
                "-d",
                "-D",
                "../${workspaceFolderBasename}"
            ],
        },
        {
            "label": "Run Unit Tests",
            "type": "shell",
            "command": "python3",
            "args": [
                "${workspaceFolder}/../unitTests.py",
                "-v",
                "-D",
                "../${workspaceFolderBasename}"
            ],
            "group": {
                "kind": "build"
            },
        },
        {
            "label": "Clean Unit Tests",
            "type": "shell",
            "command": "rm",
            "args": [
                "-rf",
                "build"
            ],
            "group": {
                "kind": "build"
            },
        }
    ]
}